# ===========================================
# MOTTIVME Sales Dashboard - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# Supabase (Required)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_anon_key

# Google Gemini AI (Required for AI Voice Support)
VITE_GEMINI_API_KEY=your_gemini_key

# ===========================================
# IMPORTANT NOTES:
# ===========================================
# - All frontend env vars MUST start with VITE_
# - Never expose secret keys in frontend code
# - Service role keys should only be used in backend/serverless functions
